SECRET_KEY=replace-with-a-long-random-value
JWT_SECRET_KEY=replace-with-a-different-long-random-value

POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-me
POSTGRES_DB=db_server
POSTGRES_PORT=5433

HTTP_PORT=80
UPLOADS_PATH=./data/uploads
SOCKET_CORS_ORIGINS=*

# Ollama is optional. Disabled uses grounded-template-v1 content and rule-v1 matching.
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3-vl:4b
OLLAMA_TIMEOUT_SECONDS=60
OLLAMA_CONTENT_TIMEOUT_SECONDS=60

MATCH_MIN_SCORE=50
MATCH_NOTIFY_SCORE=85
